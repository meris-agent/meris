# Meris local config — created by `meris init-harness` when .env is missing.
# Fill API key for your provider; see docs/USER_SETUP.md

# MERIS_PROVIDER=deepseek
# DEEPSEEK_API_KEY=

# Rust agent loop when meris-rs is available (recommended)
MERIS_NATIVE_LOOP=auto
# MERIS_NATIVE_LOOP=0        # force Python loop (debug)
# MERIS_NATIVE_PROVIDER=0    # only if Rust provider fails
