# DeepSeek（OpenAI 兼容）
# 复制为 .env 并填入真实 key：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
MERIS_BASE_URL=https://api.deepseek.com/v1
MERIS_MODEL=deepseek-chat

# 或使用通用变量名
# LLM_API_KEY=
# OPENAI_API_KEY=

# 可选：Anthropic 原生
# MERIS_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# 可选：使用 meris-rs 做 context 压缩（需 meris native build）
# MERIS_NATIVE=1
