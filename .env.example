# Meris LLM — pick one provider (see: meris models list)
# Copy to .env in repo root or your project cwd.

# --- DeepSeek ---
# MERIS_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# MERIS_MODEL=deepseek-chat

# --- OpenAI ---
# MERIS_PROVIDER=openai
# OPENAI_API_KEY=

# --- Anthropic (pip install meris-agent[anthropic]) ---
# MERIS_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# --- Google Gemini (OpenAI-compatible endpoint) ---
# MERIS_PROVIDER=gemini
# GEMINI_API_KEY=

# --- 智谱 GLM ---
# MERIS_PROVIDER=glm
# ZHIPU_API_KEY=

# --- Moonshot / Kimi ---
# MERIS_PROVIDER=moonshot
# MOONSHOT_API_KEY=

# --- 阿里通义 / 百炼 (DashScope OpenAI 兼容) ---
# MERIS_PROVIDER=qwen
# DASHSCOPE_API_KEY=
# MERIS_MODEL=qwen-plus

# --- 火山引擎 方舟 / 豆包 ---
# MERIS_PROVIDER=volcengine
# ARK_API_KEY=
# MERIS_MODEL=ep-xxxxxxxx

# --- 自部署 vLLM / Xinference / LiteLLM ---
# MERIS_PROVIDER=local
# MERIS_BASE_URL=http://127.0.0.1:8000/v1
# MERIS_MODEL=your-model
# OPENAI_API_KEY=not-needed

# --- Groq / Mistral / OpenRouter ---
# MERIS_PROVIDER=groq
# GROQ_API_KEY=
# MERIS_PROVIDER=mistral
# MISTRAL_API_KEY=
# MERIS_PROVIDER=openrouter
# OPENROUTER_API_KEY=

# --- Ollama (local, no key required) ---
# MERIS_PROVIDER=ollama
# MERIS_MODEL=llama3.2

# Override preset defaults (any provider):
# MERIS_BASE_URL=https://api.deepseek.com/v1
# MERIS_MODEL=deepseek-chat

# Legacy names still work: LLM_API_KEY, LLM_BASE_URL, LLM_MODEL, LLM_PROVIDER

# Optional: meris-rs context compression
# MERIS_NATIVE=1
