{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Git",
      "Bash(pytest*)",
      "Bash(python*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "MCP"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push*)",
      "Bash(curl*)"
    ]
  },
  "sensors": {
    "postEdit": ["pytest tests/ -m \"not integration\" -q --tb=no"],
    "onComplete": true
  },
  "context": {
    "maxMessages": 48,
    "maxTokens": 32000,
    "maxToolTokens": 2000
  },
  "blockedPaths": ["**/generated/**", "**/node_modules/**"],
  "hooks": {
    "preToolUse": [],
    "postToolUse": []
  },
  "mcpServers": {},
  "models": {
    "byMode": {
      "ask": { "provider": "deepseek", "model": "deepseek-chat" },
      "plan": { "provider": "deepseek", "model": "deepseek-chat" },
      "run": { "provider": "volcengine", "model": "ep-xxxxxxxx" }
    },
    "rules": [
      {
        "name": "heavy-refactor",
        "match": { "mode": "run", "taskContains": ["重构", "refactor", "架构"] },
        "provider": "anthropic",
        "model": "claude-sonnet-4-20250514"
      }
    ]
  }
}
